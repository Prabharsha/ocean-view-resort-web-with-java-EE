@startuml Sequence_CreateReservation
' ============================================================
' Figure 4: Sequence Diagram — Create New Reservation
' Created using PlantUML following UML 2.5 notation
' ============================================================

skinparam sequence {
    ArrowColor #2E86AB
    LifeLineBorderColor #1A3C5E
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #F0F8FF
}

title Sequence Diagram — Create New Reservation

actor "Staff" as Actor
participant "<<servlet>>\nReservationController" as RC
participant "<<service>>\nReservationServiceImpl" as RS
participant "<<utility>>\nValidationUtil" as VU
participant "<<dao>>\nRoomDAOImpl" as RD
participant "<<dao>>\nReservationDAOImpl" as RvD
participant "<<dao>>\nGuestDAOImpl" as GD
participant "<<utility>>\nEmailUtil" as EU
participant "<<utility>>\nSessionUtil" as SU
database "MySQL\nDatabase" as MySQL

== Display New Reservation Form ==

Actor -> RC : GET /reservations?action=new
activate RC

RC -> SU : getLoggedUser(request)
activate SU
SU --> RC : User (logged-in staff)
deactivate SU

RC -> RS : (via RoomService)\ngetAvailableRooms()
activate RS
RS --> RC : List<Room>
deactivate RS

RC -> RS : (via GuestService)\ngetAllGuests()
activate RS
RS --> RC : List<Guest>
deactivate RS

RC -> RC : generateCsrfToken(request)
RC --> Actor : forward to add.jsp\n(rooms, guests, csrfToken)
deactivate RC

== Submit Reservation Form ==

Actor -> RC : POST /reservations\n(action=create, guestId, roomId,\ncheckInDate, checkOutDate, numGuests,\nspecialRequests, csrfToken)
activate RC

RC -> RC : validateCsrf(request, response)
note right: CSRF token matched ✓

RC -> SU : getLoggedUser(request)
activate SU
SU --> RC : User (staff)
deactivate SU

RC -> RC : Build Reservation object\nfrom request parameters

RC -> RS : createReservation(reservation, userId)
activate RS

' --- Validation Phase ---
RS -> VU : isNullOrEmpty(guestId)
activate VU
VU --> RS : false
deactivate VU

RS -> VU : isNullOrEmpty(roomId)
activate VU
VU --> RS : false
deactivate VU

RS -> RS : validate dates:\ncheckOut > checkIn,\ncheckIn >= today

RS -> RS : validate numGuests >= 1

' --- Capacity Check ---
RS -> RD : findById(roomId)
activate RD
RD -> MySQL : SELECT * FROM rooms WHERE id = ?
activate MySQL
MySQL --> RD : ResultSet
deactivate MySQL
RD --> RS : Room object
deactivate RD

RS -> RS : check numGuests <= room.capacity

alt Validation fails (any check)
    RS --> RC : ServiceResult.failure(errorMessage)
    RC -> RC : req.setAttribute("error", message)
    RC --> Actor : forward to add.jsp (error)
else All validations pass

    ' --- Persist Reservation ---
    RS -> RS : setId(UUID), setCreatedBy(userId),\nsetStatus("PENDING")

    RS -> RvD : save(reservation)
    activate RvD
    RvD -> MySQL : INSERT INTO reservations\n(id, guest_id, room_id,\ncheck_in_date, check_out_date,\nnum_guests, status, created_by, ...)
    activate MySQL

    alt Double-booking detected (DB trigger)
        MySQL --> RvD : ERROR: Room already booked
        RvD --> RS : DAOException("Room already booked")
        RS --> RC : ServiceResult.failure(\n"Room is already booked\nfor the selected dates")
        RC --> Actor : forward to add.jsp (error)
    else Insert successful
        MySQL --> RvD : success (trigger generates\nreservation_no, total_amount)
        deactivate MySQL
        RvD --> RS : void
        deactivate RvD

        ' --- Reload for generated fields ---
        RS -> RvD : findById(reservation.id)
        activate RvD
        RvD -> MySQL : SELECT * FROM reservations WHERE id = ?
        activate MySQL
        MySQL --> RvD : ResultSet
        deactivate MySQL
        RvD --> RS : saved Reservation\n(with reservation_no, total_amount)
        deactivate RvD

        ' --- Send Confirmation Email ---
        RS -> GD : findById(guestId)
        activate GD
        GD -> MySQL : SELECT * FROM guests WHERE id = ?
        activate MySQL
        MySQL --> GD : ResultSet
        deactivate MySQL
        GD --> RS : Guest object
        deactivate GD

        opt Guest has email address
            RS -> EU : sendReservationConfirmation(\nemail, guestName, reservationNo,\ncheckIn, checkOut, totalAmount)
            activate EU
            EU -> EU : new Thread() → send SMTP
            EU --> RS : void (async)
            deactivate EU
        end

        RS --> RC : ServiceResult.success(\n"Reservation RES-0001 created", savedReservation)
    end
end

deactivate RS

opt Success
    RC -> RC : session.setAttribute(\n"flashSuccess", message)
    RC --> Actor : redirect to\n/reservations?action=view&id=...
end

deactivate RC

@enduml


@startuml Sequence_SearchReservation
title Sequence Diagram - Search and Display Reservation Details

actor "Staff" as Actor
participant "ReservationController" as RC
participant "ReservationServiceImpl" as RS
participant "GuestServiceImpl" as GS
participant "RoomServiceImpl" as RMS
participant "PaymentServiceImpl" as PS
participant "ReservationDAOImpl" as RvD
participant "GuestDAOImpl" as GD
participant "RoomDAOImpl" as RD
database "MySQL" as MySQL

== List All Reservations ==

Actor -> RC : GET /reservations?action=list
activate RC

RC -> RS : getAllReservations()
activate RS
RS -> RvD : findAll()
activate RvD
RvD -> MySQL : SELECT * FROM reservations ORDER BY created_at DESC
MySQL --> RvD : ResultSet (multiple rows)
RvD --> RS : List<Reservation>
deactivate RvD
RS --> RC : List<Reservation>
deactivate RS

loop for each Reservation r in list
    RC -> GS : getGuestById(r.guestId)
    GS --> RC : Guest
    RC -> RC : r.setGuestName(guest.getName())
    RC -> RMS : getRoom(r.roomId)
    RMS --> RC : Room
    RC -> RC : r.setRoomNumber(room.getRoomNumber())
end

RC --> Actor : forward list.jsp (reservations with guest/room names)
deactivate RC

== Filter Reservations by Status ==

Actor -> RC : GET /reservations?action=list&status=CONFIRMED
activate RC
RC -> RS : getReservationsByStatus("CONFIRMED")
activate RS
RS -> RvD : findByStatus("CONFIRMED")
activate RvD
RvD -> MySQL : SELECT * FROM reservations WHERE status=?
MySQL --> RvD : ResultSet
RvD --> RS : List<Reservation>
deactivate RvD
RS --> RC : List<Reservation>
deactivate RS
RC --> Actor : forward list.jsp (filtered results)
deactivate RC

== View Single Reservation Detail ==

Actor -> RC : GET /reservations?action=view&id=xyz
activate RC

RC -> RS : getReservation(id)
activate RS
RS -> RvD : findById(id)
activate RvD
RvD -> MySQL : SELECT * FROM reservations WHERE id=?
MySQL --> RvD : ResultSet
RvD --> RS : Reservation
deactivate RvD
RS --> RC : Reservation
deactivate RS

alt Reservation not found
    RC --> Actor : HTTP 404 "Reservation not found"
else Reservation found
    RC -> GS : getGuestById(reservation.guestId)
    activate GS
    GS -> GD : findById(guestId)
    GD -> MySQL : SELECT * FROM guests WHERE id=?
    MySQL --> GD : ResultSet
    GD --> GS : Guest
    GS --> RC : Guest
    deactivate GS

    RC -> RMS : getRoom(reservation.roomId)
    activate RMS
    RMS -> RD : findById(roomId)
    RD -> MySQL : SELECT * FROM rooms WHERE id=?
    MySQL --> RD : ResultSet
    RD --> RMS : Room
    RMS --> RC : Room
    deactivate RMS

    RC -> PS : getPaymentByReservation(id)
    activate PS
    PS --> RC : Payment (or null)
    deactivate PS

    RC -> RC : generateCsrfToken(request)
    RC --> Actor : forward view.jsp\n(reservation, guest, room, payment)
end

deactivate RC

@enduml


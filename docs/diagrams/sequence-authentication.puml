@startuml Sequence_Authentication
' ============================================================
' Figure 3: Sequence Diagram — User Authentication
' Created using PlantUML following UML 2.5 notation
' ============================================================

skinparam sequence {
    ArrowColor #2E86AB
    LifeLineBorderColor #1A3C5E
    ParticipantBorderColor #2E86AB
    ParticipantBackgroundColor #F0F8FF
}

title Sequence Diagram — User Authentication

actor "Staff / Manager / Admin" as Actor
participant "<<servlet>>\nAuthController" as AC
participant "<<filter>>\nAuthFilter" as AF
participant "<<service>>\nUserServiceImpl" as US
participant "<<utility>>\nValidationUtil" as VU
participant "<<dao>>\nUserDAOImpl" as UD
participant "<<utility>>\nPasswordUtil" as PU
participant "<<utility>>\nDBConnection" as DB
participant "<<utility>>\nSessionUtil" as SU
database "MySQL\nDatabase" as MySQL

== Login Request ==

Actor -> AC : POST /auth (username, password)
activate AC

AC -> US : authenticate(username, password)
activate US

US -> VU : isNullOrEmpty(username)
activate VU
VU --> US : false
deactivate VU

US -> VU : isNullOrEmpty(password)
activate VU
VU --> US : false
deactivate VU

US -> UD : findByUsername(username)
activate UD

UD -> DB : getInstance()
activate DB
DB --> UD : DBConnection instance
deactivate DB

UD -> DB : getConnection()
activate DB
DB --> UD : Connection
deactivate DB

UD -> MySQL : SELECT * FROM users WHERE username = ?
activate MySQL
MySQL --> UD : ResultSet
deactivate MySQL

UD -> UD : mapper.mapRow(ResultSet)
UD --> US : User object
deactivate UD

alt User not found
    US --> AC : ServiceResult.failure("Invalid username or password")
    AC -> AC : req.setAttribute("error", message)
    AC --> Actor : forward to login.jsp (error)
else User is deactivated
    US --> AC : ServiceResult.failure("Account is deactivated")
    AC -> AC : req.setAttribute("error", message)
    AC --> Actor : forward to login.jsp (error)
else User found and active
    US -> PU : check(password, user.getPassword())
    activate PU
    PU --> US : boolean match
    deactivate PU

    alt Password does not match
        US --> AC : ServiceResult.failure("Invalid username or password")
        AC --> Actor : forward to login.jsp (error)
    else Password matches
        US -> UD : updateLastLogin(userId)
        activate UD
        UD -> MySQL : UPDATE users SET last_login = NOW()
        activate MySQL
        MySQL --> UD : success
        deactivate MySQL
        UD --> US : void
        deactivate UD

        US --> AC : ServiceResult.success("Login successful", user)
    end
end

deactivate US

opt Successful authentication
    AC -> SU : createSession(request, user)
    activate SU
    SU -> SU : session.setAttribute("loggedUser", user)
    SU -> SU : session.setAttribute("userRole", role)
    SU -> SU : session.setMaxInactiveInterval(1800)
    SU --> AC : void
    deactivate SU

    AC --> Actor : redirect to /dashboard
end

deactivate AC

== Subsequent Authenticated Request ==

Actor -> AF : GET /dashboard
activate AF
AF -> SU : isLoggedIn(request)
activate SU
SU --> AF : true
deactivate SU
AF -> AF : chain.doFilter()
AF --> Actor : forward to dashboard
deactivate AF

== Logout ==

Actor -> AC : GET /auth?action=logout
activate AC
AC -> SU : invalidate(request)
activate SU
SU -> SU : session.invalidate()
SU --> AC : void
deactivate SU
AC --> Actor : redirect to /auth?action=loginForm
deactivate AC

@enduml

